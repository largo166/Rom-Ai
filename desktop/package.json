{
  "name": "rom-ai-desktop",
  "version": "1.0.2",
  "description": "ROM-AI local desktop application",
  "author": "ROM-AI",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "tree-kill": "^1.2.2",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rmo-ai.desktop",
    "productName": "Rmo-AI",
    "asar": true,
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../backend/dist/rmo-ai-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ROM-AI-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Leslie0Han",
        "repo": "ROM-AI-local-demo"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ROM-AI"
    }
  }
}
